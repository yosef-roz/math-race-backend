<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class name="com.example.math_race.entities.UserEntity" table="users" lazy="false">
        <id name="id" type="org.hibernate.type.UUIDBinaryType">
            <column name="id" length="16" />
            <generator class="org.hibernate.id.UUIDGenerator"/>
        </id>

        <property name="username" type="string" column="username" not-null="true" unique="true"/>
        <property name="email" type="string" column="email" not-null="true" unique="true"/>
        <property name="password" type="string" column="password" not-null="true"/>
        <property name="verified" type="boolean" column="verified" not-null="true"/>

        <property name="role" column="role" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">com.example.math_race.entities.UserEntity$UserRole</param>
                <param name="useNamed">true</param>
            </type>
        </property>

        <property name="creationDate" type="java.util.Date" column="creation_date" not-null="true"/>
        <property name="updatedDate" type="java.util.Date" column="updated_date"/>
        <property name="deleted" type="boolean" column="deleted" not-null="true"/>
        <property name="deletionDate" type="java.util.Date" column="deletion_date"/>
    </class>

    <class name="com.example.math_race.entities.TokenEntity" table="tokens" lazy="false">
        <id name="id" type="org.hibernate.type.UUIDBinaryType">
            <column name="id" length="16" />
            <generator class="org.hibernate.id.UUIDGenerator"/>
        </id>

        <many-to-one name="user"
                     class="com.example.math_race.entities.UserEntity"
                     column="user_id"
                     not-null="true"
                     fetch="join"/>

        <property name="token" type="string" column="token" unique="true" not-null="true"/>

        <property name="type" column="token_type" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">com.example.math_race.entities.TokenEntity$TokenType</param>
                <param name="useNamed">true</param>
            </type>
        </property>

        <property name="expiresAt" type="java.util.Date" column="expires_at" not-null="true"/>
        <property name="revoked" type="boolean" column="is_revoked" not-null="true"/>
        <property name="ipAddress" type="string" column="ip_address"/>
        <property name="userAgent" type="string" column="user_agent"/>

        <property name="creationDate" type="java.util.Date" column="creation_date" not-null="true"/>
        <property name="updatedDate" type="java.util.Date" column="updated_date"/>
        <property name="deleted" type="boolean" column="deleted" not-null="true"/>
        <property name="deletionDate" type="java.util.Date" column="deletion_date"/>
    </class>

    <class name="com.example.math_race.entities.RaceHistoryEntity" table="race_history" lazy="false">
        <id name="id" type="org.hibernate.type.UUIDBinaryType">
            <column name="id" length="16" />
            <generator class="org.hibernate.id.UUIDGenerator"/>
        </id>

        <property name="hostId" type="string" column="host_id" index="idx_race_host_deleted" not-null="true"/>
        <property name="hostNickname" type="string" column="host_nickname" not-null="true"/>

        <property name="name" type="string" column="race_name" not-null="true"/>
        <property name="roomCode" type="string" column="room_code" not-null="true"/>
        <property name="targetScore" type="int" column="target_score" not-null="true"/>
        <property name="private" type="java.lang.Boolean" column="private_room" not-null="true"/>

        <property name="createdAtMs" type="long" column="created_at_millis" not-null="true"/>
        <property name="endedAtMs" type="long" column="ended_at_millis" not-null="true"/>
        <property name="totalDurationMillis" type="long" column="total_duration_millis" not-null="true"/>
        <property name="totalPausedDurationMillis" type="long" column="total_paused_duration_millis" not-null="true"/>
        <property name="totalParticipants" type="int" column="total_participants" not-null="true"/>

        <property name="status" column="race_status" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">com.example.math_race.race.RaceStatus</param>
                <param name="useNamed">true</param>
            </type>
        </property>

        <property name="streakMasterId" type="string" column="streak_master_id"/>
        <property name="streakMasterNickname" type="string" column="streak_master_nickname"/>
        <property name="streakMasterAmount" type="int" column="streak_master_amount" not-null="true"/>

        <property name="accuracyKingId" type="string" column="accuracy_king_id"/>
        <property name="accuracyKingNickname" type="string" column="accuracy_king_nickname"/>
        <property name="accuracyKingPercentage" type="double" column="accuracy_king_percentage" not-null="true"/>

        <property name="speedDemonId" type="string" column="speed_demon_id"/>
        <property name="speedDemonNickname" type="string" column="speed_demon_nickname"/>
        <property name="speedDemonTimeMs" type="double" column="speed_demon_time_ms" not-null="true"/>

        <property name="accuracyPercentage" type="double" column="accuracy_percentage" not-null="true"/>
        <property name="autostradaPercentage" type="double" column="autostrada_percentage" not-null="true"/>
        <property name="dirtRoadPercentage" type="double" column="dirt_road_percentage" not-null="true"/>
        <property name="averageResponseTimeMs" type="long" column="average_response_time_ms" not-null="true"/>
        <property name="totalJunctionsOffered" type="int" column="total_junctions_offered" not-null="true"/>

        <property name="creationDate" type="java.util.Date" column="creation_date" not-null="true"/>
        <property name="updatedDate" type="java.util.Date" column="updated_date"/>
        <property name="deleted" type="boolean" column="deleted" not-null="true"/>
        <property name="deletionDate" type="java.util.Date" column="deletion_date"/>
    </class>

    <class name="com.example.math_race.entities.RaceParticipantHistoryEntity" table="race_participant" lazy="false">
        <id name="id" type="org.hibernate.type.UUIDBinaryType">
            <column name="id" length="16" />
            <generator class="org.hibernate.id.UUIDGenerator"/>
        </id>

        <many-to-one name="race"
                     class="com.example.math_race.entities.RaceHistoryEntity"
                     not-null="true">
            <column name="race_id" index="idx_participant_race_id" />
        </many-to-one>

        <many-to-one name="user"
                     class="com.example.math_race.entities.UserEntity"
                     not-null="false">
            <column name="user_id" index="idx_participant_user_id" />
        </many-to-one>

        <property name="guestId" type="string" column="guest_id" not-null="false"/>
        <property name="nickname" type="string" column="nick_name" not-null="true"/>
        <property name="finalScore" type="int" column="final_score" not-null="true"/>
        <property name="rank" type="int" column="player_rank" not-null="true"/>
        <property name="hintsReceived" type="int" column="hints_received" not-null="true"/>

        <property name="regularQAttempts" type="int" column="regular_q_attempts" not-null="true"/>
        <property name="regularQSuccesses" type="int" column="regular_q_successes" not-null="true"/>
        <property name="regularQTimeMs" type="long" column="regular_q_time_ms" not-null="true"/>
        <property name="maxRegularStreak" type="int" column="max_regular_streak" not-null="true"/>
        <property name="regularSuccessTimeMs" type="long" column="regular_success_time_ms" not-null="true"/>

        <property name="junctionsOfferedCount" type="int" column="junctions_offered_count" not-null="true"/>
        <property name="autostradaChoices" type="int" column="autostrada_choices" not-null="true"/>
        <property name="dirtRoadChoices" type="int" column="dirt_road_choices" not-null="true"/>

        <property name="creationDate" type="java.util.Date" column="creation_date" not-null="true"/>
        <property name="updatedDate" type="java.util.Date" column="updated_date"/>
        <property name="deleted" type="boolean" column="deleted" not-null="true"/>
        <property name="deletionDate" type="java.util.Date" column="deletion_date"/>
    </class>

    <class name="com.example.math_race.entities.dictionary.AdjectiveEntity" table="adjectives" lazy="false">
        <id name="id" type="org.hibernate.type.UUIDBinaryType">
            <column name="id" length="16" />
            <generator class="org.hibernate.id.UUIDGenerator"/>
        </id>

        <property name="adjectiveId" type="string" column="adjective_id" not-null="true" index="idx_adjective_id"/>

        <property name="type" column="adjective_type" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">com.example.math_race.questionGenerator.tags.enums.AdjectiveType</param>
                <param name="useNamed">true</param>
            </type>
        </property>

        <set name="dbForms" table="adjective_forms" lazy="false" cascade="all">
            <key not-null="true">
                <column name="adjective_uuid" length="16" />
            </key>

            <composite-element class="com.example.math_race.entities.dictionary.AdjectiveFormEntry">
                <property name="gender" column="form_gender" length="20" not-null="true">
                    <type name="org.hibernate.type.EnumType">
                        <param name="enumClass">com.example.math_race.questionGenerator.tags.enums.Gender</param>
                        <param name="useNamed">true</param>
                    </type>
                </property>

                <property name="plurality" column="form_plurality" length="20" not-null="true">
                    <type name="org.hibernate.type.EnumType">
                        <param name="enumClass">com.example.math_race.questionGenerator.tags.enums.Plurality</param>
                        <param name="useNamed">true</param>
                    </type>
                </property>

                <property name="value" type="string" column="form_value" length="100" not-null="true"/>
            </composite-element>
        </set>

        <property name="creationDate" type="java.util.Date" column="creation_date" not-null="true"/>
        <property name="updatedDate" type="java.util.Date" column="updated_date"/>
        <property name="deleted" type="boolean" column="deleted" not-null="true"/>
        <property name="deletionDate" type="java.util.Date" column="deletion_date"/>
    </class>

    <class name="com.example.math_race.entities.dictionary.HumanEntity" table="humans" lazy="false">
        <id name="id" type="org.hibernate.type.UUIDBinaryType">
            <column name="id" length="16" />
            <generator class="org.hibernate.id.UUIDGenerator"/>
        </id>

        <property name="name" type="string" column="name" not-null="true"/>

        <property name="gender" column="gender" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">com.example.math_race.questionGenerator.tags.enums.Gender</param>
                <param name="useNamed">true</param>
            </type>
        </property>

        <property name="creationDate" type="java.util.Date" column="creation_date" not-null="true"/>
        <property name="updatedDate" type="java.util.Date" column="updated_date"/>
        <property name="deleted" type="boolean" column="deleted" not-null="true"/>
        <property name="deletionDate" type="java.util.Date" column="deletion_date"/>
    </class>

    <class name="com.example.math_race.entities.dictionary.ItemEntity" table="items" lazy="false">
        <id name="id" type="org.hibernate.type.UUIDBinaryType">
            <column name="id" length="16" />
            <generator class="org.hibernate.id.UUIDGenerator"/>
        </id>

        <property name="itemId" type="string" column="item_id" not-null="true" index="idx_item_id"/>

        <property name="singular" type="string" column="singular" not-null="true"/>
        <property name="plural" type="string" column="plural" not-null="true"/>

        <property name="gender" column="gender" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">com.example.math_race.questionGenerator.tags.enums.Gender</param>
                <param name="useNamed">true</param>
            </type>
        </property>

        <set name="categories" table="item_categories" lazy="false">
            <key not-null="true">
                <column name="item_uuid" length="16" />
            </key>
            <element column="category">
                <type name="org.hibernate.type.EnumType">
                    <param name="enumClass">com.example.math_race.questionGenerator.tags.enums.ItemCategory</param>
                    <param name="useNamed">true</param>
                </type>
            </element>
        </set>

        <set name="allowedUnits" table="item_allowed_units" lazy="false">
            <key not-null="true">
                <column name="item_uuid" length="16" />
            </key>
            <element column="unit_type">
                <type name="org.hibernate.type.EnumType">
                    <param name="enumClass">com.example.math_race.questionGenerator.tags.enums.UnitType</param>
                    <param name="useNamed">true</param>
                </type>
            </element>
        </set>

        <property name="creationDate" type="java.util.Date" column="creation_date" not-null="true"/>
        <property name="updatedDate" type="java.util.Date" column="updated_date"/>
        <property name="deleted" type="boolean" column="deleted" not-null="true"/>
        <property name="deletionDate" type="java.util.Date" column="deletion_date"/>
    </class>

    <class name="com.example.math_race.entities.dictionary.PlaceEntity" table="places" lazy="false">
        <id name="id" type="org.hibernate.type.UUIDBinaryType">
            <column name="id" length="16" />
            <generator class="org.hibernate.id.UUIDGenerator"/>
        </id>

        <property name="placeId" type="string" column="place_id" not-null="true" index="idx_place_id"/>

        <property name="singular" type="string" column="singular" not-null="true"/>
        <property name="plural" type="string" column="plural" not-null="true"/>

        <property name="gender" column="gender" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">com.example.math_race.questionGenerator.tags.enums.Gender</param>
                <param name="useNamed">true</param>
            </type>
        </property>

        <property name="placeType" column="place_type" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">com.example.math_race.questionGenerator.tags.enums.PlaceType</param>
                <param name="useNamed">true</param>
            </type>
        </property>

        <set name="availableItemCategories" table="place_available_categories" lazy="false">
            <key not-null="true">
                <column name="place_uuid" length="16" />
            </key>
            <element column="item_category">
                <type name="org.hibernate.type.EnumType">
                    <param name="enumClass">com.example.math_race.questionGenerator.tags.enums.ItemCategory</param>
                    <param name="useNamed">true</param>
                </type>
            </element>
        </set>

        <property name="creationDate" type="java.util.Date" column="creation_date" not-null="true"/>
        <property name="updatedDate" type="java.util.Date" column="updated_date"/>
        <property name="deleted" type="boolean" column="deleted" not-null="true"/>
        <property name="deletionDate" type="java.util.Date" column="deletion_date"/>
    </class>

    <class name="com.example.math_race.entities.dictionary.RoleEntity" table="roles" lazy="false">
        <id name="id" type="org.hibernate.type.UUIDBinaryType">
            <column name="id" length="16" />
            <generator class="org.hibernate.id.UUIDGenerator"/>
        </id>

        <property name="roleId" type="string" column="role_id" not-null="true" index="idx_role_id"/>

        <property name="singularMale" type="string" column="singular_male" not-null="true"/>
        <property name="pluralMale" type="string" column="plural_male" not-null="true"/>
        <property name="singularFemale" type="string" column="singular_female" not-null="true"/>
        <property name="pluralFemale" type="string" column="plural_female" not-null="true"/>

        <property name="roleType" column="role_type" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">com.example.math_race.questionGenerator.tags.enums.RoleType</param>
                <param name="useNamed">true</param>
            </type>
        </property>

        <set name="validPlaceIds" table="role_valid_places" lazy="false">
            <key not-null="true">
                <column name="role_uuid" length="16" />
            </key>
            <element column="place_id" type="string"/> </set>

        <property name="creationDate" type="java.util.Date" column="creation_date" not-null="true"/>
        <property name="updatedDate" type="java.util.Date" column="updated_date"/>
        <property name="deleted" type="boolean" column="deleted" not-null="true"/>
        <property name="deletionDate" type="java.util.Date" column="deletion_date"/>
    </class>

    <class name="com.example.math_race.entities.dictionary.UnitEntity" table="units" lazy="false">
        <id name="id" type="org.hibernate.type.UUIDBinaryType">
            <column name="id" length="16" />
            <generator class="org.hibernate.id.UUIDGenerator"/>
        </id>

        <property name="unitId" type="string" column="unit_id" not-null="true" index="idx_unit_id"/>

        <property name="singular" type="string" column="singular" not-null="true"/>
        <property name="plural" type="string" column="plural" not-null="true"/>

        <property name="gender" column="gender" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">com.example.math_race.questionGenerator.tags.enums.Gender</param>
                <param name="useNamed">true</param>
            </type>
        </property>

        <property name="type" column="unit_type" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">com.example.math_race.questionGenerator.tags.enums.UnitType</param>
                <param name="useNamed">true</param>
            </type>
        </property>

        <set name="validItemCategories" table="unit_valid_categories" lazy="false">
            <key not-null="true">
                <column name="unit_uuid" length="16" />
            </key>
            <element column="item_category">
                <type name="org.hibernate.type.EnumType">
                    <param name="enumClass">com.example.math_race.questionGenerator.tags.enums.ItemCategory</param>
                    <param name="useNamed">true</param>
                </type>
            </element>
        </set>

        <property name="creationDate" type="java.util.Date" column="creation_date" not-null="true"/>
        <property name="updatedDate" type="java.util.Date" column="updated_date"/>
        <property name="deleted" type="boolean" column="deleted" not-null="true"/>
        <property name="deletionDate" type="java.util.Date" column="deletion_date"/>
    </class>
</hibernate-mapping>
